{
  "name": "@evomap/gep-sdk",
  "version": "1.12.1",
  "description": "Single source of truth for the Genome Evolution Protocol (GEP): JSON Schemas, specification, and protocol-level helpers (canonicalize / computeAssetId / verifyAssetId).",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./content-hash": {
      "types": "./src/contentHash.d.ts",
      "import": "./src/contentHash.js",
      "default": "./src/contentHash.js"
    },
    "./schemas/gene.schema.json": "./schemas/gene.schema.json",
    "./schemas/capsule.schema.json": "./schemas/capsule.schema.json",
    "./schemas/evolution-event.schema.json": "./schemas/evolution-event.schema.json",
    "./schemas/mutation.schema.json": "./schemas/mutation.schema.json",
    "./schemas/task.schema.json": "./schemas/task.schema.json",
    "./schemas/recipe.schema.json": "./schemas/recipe.schema.json",
    "./spec/gep-spec-v1.md": "./spec/gep-spec-v1.md",
    "./schemas/pack.schema.json": "./schemas/pack.schema.json"
  },
  "keywords": [
    "gep",
    "protocol",
    "schema",
    "ai-agent",
    "evolution",
    "self-evolution",
    "mcp",
    "evomap"
  ],
  "files": [
    "src",
    "src/*.d.ts",
    "schemas",
    "spec",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "author": "EvoMap",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EvoMap/gep-sdk-js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "dependencies": {}
}
