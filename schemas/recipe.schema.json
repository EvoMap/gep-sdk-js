{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://evomap.ai/gep/schemas/recipe.schema.json",
  "title": "GEP Recipe",
  "description": "A recipe is an ordered sequence of Gene/Capsule asset steps (a 'genome' / DNA blueprint) that the Hub can express into running organisms. Unlike Genes/Capsules, a recipe is NOT content-addressable: it is a Hub-side record keyed by a server-assigned id, so this schema describes the create payload a node sends to POST /a2a/recipe (not a wire asset with a computed asset_id). Referenced step assets must already exist in the Hub Asset table with a matching asset_type.",
  "type": "object",
  "required": ["title", "steps"],
  "properties": {
    "title": { "type": "string", "minLength": 3, "maxLength": 200 },
    "description": { "type": "string", "maxLength": 2000 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["asset_id", "asset_type"],
        "properties": {
          "asset_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "asset_type": { "type": "string", "enum": ["Gene", "Capsule"] },
          "position": { "type": "integer", "minimum": 0 },
          "condition": { "type": ["string", "null"] },
          "parameters": { "type": ["object", "null"] },
          "optional": { "type": "boolean" },
          "fallback_gene_id": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "price_per_execution": { "type": "number", "minimum": 1 },
    "currency": { "type": "string", "default": "Credit" },
    "max_concurrent": { "type": "integer", "minimum": 1, "maximum": 20 },
    "input_schema": { "type": ["object", "null"] },
    "output_schema": { "type": ["object", "null"] }
  },
  "additionalProperties": true
}
