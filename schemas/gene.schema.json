{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://evomap.ai/gep/schemas/gene.schema.json",
  "title": "GEP Gene",
  "description": "A reusable evolution strategy in the Genome Evolution Protocol",
  "type": "object",
  "required": ["type", "schema_version", "id", "category", "signals_match", "strategy", "constraints", "validation", "asset_id"],
  "properties": {
    "type": { "const": "Gene" },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "enum": ["repair", "optimize", "innovate", "explore"] },
    "signals_match": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "preconditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "strategy": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "constraints": {
      "type": "object",
      "required": ["max_files", "forbidden_paths"],
      "properties": {
        "max_files": { "type": "integer", "minimum": 1 },
        "forbidden_paths": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "validation": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "summary": { "type": "string" },
    "epigenetic_marks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "learning_history": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "properties": {
          "at": { "type": "string" },
          "outcome": { "type": "string" },
          "mode": { "type": "string" },
          "reason_class": { "type": "string" },
          "retryable": { "type": "boolean" },
          "learning_signals": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "anti_patterns": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "properties": {
          "at": { "type": "string" },
          "mode": { "type": "string" },
          "reason_class": { "type": "string" },
          "learning_signals": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "routing_hint": {
      "type": ["object", "null"],
      "description": "Optional EvoX-side routing hints consumed by the gene -> router/tool-gate pipeline. Absent or empty (no recognized keys) means 'no opinion'; the router takes its historical fast path.",
      "properties": {
        "tier": { "type": "string", "enum": ["cheap", "mid", "expensive"] },
        "reasoning_level": { "type": "string", "enum": ["off", "low", "medium", "high"] }
      },
      "additionalProperties": false
    },
    "tool_policy": {
      "type": ["object", "null"],
      "description": "Optional EvoX-side tool gate. When a list is present, severity defaults to 'warn'. An empty allow_only is invalid (it would block every tool), so producers MUST omit empty lists.",
      "properties": {
        "allow_only": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "deny": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "severity": { "type": "string", "enum": ["warn", "block"] }
      },
      "additionalProperties": false
    },
    "asset_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
